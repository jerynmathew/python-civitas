"""Run the $project_name agent system."""

import asyncio

from civitas import Runtime

from agents import GreeterAgent


async def main() -> None:
    runtime = Runtime.from_config("topology.yaml", agent_classes={
        "agents.GreeterAgent": GreeterAgent,
    })
    await runtime.start()

    try:
        result = await runtime.ask("greeter", {"name": "Agency"})
        print(f"Response: {result.payload}")
    finally:
        await runtime.stop()


if __name__ == "__main__":
    asyncio.run(main())
